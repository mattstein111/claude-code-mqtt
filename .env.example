# MQTT broker connection
MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Session name — used for topic routing (chachi/sessions/<name>/inbox)
SESSION_NAME=primary

# Topics to subscribe to on startup (comma-separated)
SUBSCRIBE_TOPICS=chachi/sessions/primary/inbox,chachi/broadcast

# QoS level (0=at most once, 1=at least once, 2=exactly once)
QOS=1
