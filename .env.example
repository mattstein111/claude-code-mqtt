# MQTT broker connection
MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Session identity
# SESSION_NAME=primary

# Topic prefix (default: claude). All session topics use this as the root namespace.
# e.g., <prefix>/sessions/<name>/inbox
# MQTT_TOPIC_PREFIX=claude

# QoS level (0=at most once, 1=at least once, 2=exactly once)
QOS=1

# Heartbeat interval in seconds (retained status message updated on this cadence)
# HEARTBEAT_INTERVAL=60

# Request/reply timeout in seconds (how long the request tool waits for a correlated response)
# MQTT_REQUEST_TIMEOUT=120

# Security: max inbound payload size in bytes (default: 256KB)
# MQTT_MAX_PAYLOAD_BYTES=262144

# Security: max concurrent pending request/reply operations (default: 50)
# MQTT_MAX_PENDING_REQUESTS=50
